{
  "version": 1,
  "author": "Patxi-Sallaberry",
  "editor": "wokwi",
  "//": "Copie du diagramme avec T procédé = 35 °C pour tester l'état ALARME (le capteur NTC n'étant pilotable qu'à l'initialisation).",
  "parts": [
    { "type": "wokwi-arduino-uno", "id": "uno", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "wokwi-ntc-temperature-sensor",
      "id": "ntc1",
      "top": -120,
      "left": 130,
      "attrs": { "temperature": "35" }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot1",
      "top": 120,
      "left": 130,
      "attrs": {}
    }
  ],
  "connections": [
    [ "ntc1:GND", "uno:GND.1", "black", [] ],
    [ "ntc1:VCC", "uno:5V", "red", [] ],
    [ "ntc1:OUT", "uno:A0", "green", [] ],
    [ "pot1:GND", "uno:GND.2", "black", [] ],
    [ "pot1:VCC", "uno:5V", "red", [] ],
    [ "pot1:SIG", "uno:A1", "green", [] ]
  ]
}
