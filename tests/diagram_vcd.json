{
  "version": 1,
  "author": "Patxi-Sallaberry",
  "editor": "wokwi",
  "//": "Diagramme de test : identique au principal + un analyseur logique sur D9 pour exporter le chronogramme PWM (VCD). Utilisé via --diagram-file.",
  "parts": [
    { "type": "wokwi-arduino-uno", "id": "uno", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-ntc-temperature-sensor", "id": "ntc1", "top": -120, "left": 130, "attrs": { "temperature": "25" } },
    { "type": "wokwi-potentiometer", "id": "pot1", "top": 120, "left": 130, "attrs": {} },
    { "type": "wokwi-led", "id": "led_fan", "top": -200, "left": 250, "attrs": { "color": "green" } },
    { "type": "wokwi-resistor", "id": "r_fan", "top": -150, "left": 240, "attrs": { "value": "220" } },
    { "type": "wokwi-logic-analyzer", "id": "la1", "top": 250, "left": 0, "attrs": {} }
  ],
  "connections": [
    [ "ntc1:GND", "uno:GND.1", "black", [] ],
    [ "ntc1:VCC", "uno:5V", "red", [] ],
    [ "ntc1:OUT", "uno:A0", "green", [] ],
    [ "pot1:GND", "uno:GND.2", "black", [] ],
    [ "pot1:VCC", "uno:5V", "red", [] ],
    [ "pot1:SIG", "uno:A1", "green", [] ],
    [ "uno:9", "r_fan:1", "green", [] ],
    [ "r_fan:2", "led_fan:A", "green", [] ],
    [ "led_fan:C", "uno:GND.3", "black", [] ],
    [ "uno:9", "la1:D0", "orange", [] ]
  ]
}
